{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "color": {
      "palette": [
        { "slug": "teal", "color": "#7FB5B0", "name": "Teal" },
        { "slug": "teal-dark", "color": "#5A9A93", "name": "Teal Dark" },
        { "slug": "teal-light", "color": "#A8D5D0", "name": "Teal Light" },
        { "slug": "charcoal", "color": "#3A3A3A", "name": "Charcoal" },
        { "slug": "dark-slate", "color": "#4A4A4A", "name": "Dark Slate" },
        { "slug": "warm-gray", "color": "#6B6B6B", "name": "Warm Gray" },
        { "slug": "light-gray", "color": "#F5F5F3", "name": "Light Gray" },
        { "slug": "off-white", "color": "#FAFAF8", "name": "Off White" },
        { "slug": "coral", "color": "#E88B7A", "name": "Coral" },
        { "slug": "gold-star", "color": "#F5A623", "name": "Gold Star" },
        { "slug": "red-muted", "color": "#D9534F", "name": "Red Muted" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" }
      ],
      "custom": true,
      "defaultPalette": false,
      "link": true
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "'Playfair Display', serif",
          "name": "Playfair Display",
          "slug": "playfair"
        },
        {
          "fontFamily": "'Montserrat', sans-serif",
          "name": "Montserrat",
          "slug": "montserrat"
        },
        {
          "fontFamily": "'Dancing Script', cursive",
          "name": "Dancing Script",
          "slug": "dancing-script"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "12px", "name": "XS" },
        { "slug": "sm", "size": "14px", "name": "Small" },
        { "slug": "base", "size": "16px", "name": "Base" },
        { "slug": "lg", "size": "18px", "name": "Large" },
        { "slug": "xl", "size": "24px", "name": "XL" },
        { "slug": "2xl", "size": "32px", "name": "2XL" },
        { "slug": "3xl", "size": "40px", "name": "3XL" },
        { "slug": "hero", "size": "clamp(2.25rem, 5vw, 3.75rem)", "name": "Hero" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingSizes": [
        { "slug": "20", "size": "20px", "name": "20" },
        { "slug": "30", "size": "30px", "name": "30" },
        { "slug": "40", "size": "40px", "name": "40" },
        { "slug": "60", "size": "60px", "name": "60" },
        { "slug": "80", "size": "80px", "name": "80" },
        { "slug": "100", "size": "100px", "name": "100" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--off-white)",
      "text": "var(--wp--preset--color--dark-slate)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--montserrat)",
      "fontSize": "16px",
      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair)",
          "lineHeight": "1.2"
        },
        "color": { "text": "var(--wp--preset--color--charcoal)" }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--teal)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--teal-dark)" } }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--teal)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": { "radius": "9999px" },
        "typography": {
          "fontWeight": "600",
          "textTransform": "uppercase",
          "letterSpacing": "0.1em"
        },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--teal-dark)" }
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": ["page"]
    }
  ]
}
